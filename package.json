{
  "name": "@hanzogui/web",
  "version": "2.0.0",
  "license": "MIT",
  "author": {
    "name": "Nate Wienert"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/hanzoai/gui.git",
    "directory": "packages/web"
  },
  "source": "src/index.ts",
  "type": "module",
  "sideEffects": [
    "*.css"
  ],
  "main": "dist/cjs",
  "module": "dist/esm",
  "types": "./types/index.d.ts",
  "exports": {
    "./package.json": "./package.json",
    "./reset.css": "./reset.css",
    ".": {
      "types": "./types/index.d.ts",
      "react-native": "./dist/esm/index.native.js",
      "browser": "./dist/esm/index.mjs",
      "module": "./dist/esm/index.mjs",
      "import": "./dist/esm/index.mjs",
      "require": "./dist/cjs/index.cjs",
      "default": "./dist/esm/index.mjs"
    },
    "./inject-styles": {
      "types": "./types/inject-styles.d.ts",
      "react-native": "./dist/esm/inject-styles.mjs",
      "browser": "./dist/esm/inject-styles.mjs",
      "module": "./dist/esm/inject-styles.mjs",
      "import": "./dist/esm/inject-styles.mjs",
      "require": "./dist/cjs/inject-styles.cjs",
      "default": "./dist/cjs/inject-styles.cjs"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "hanzo-gui-build",
    "watch": "hanzo-gui-build --watch",
    "clean": "hanzo-gui-build clean",
    "clean:build": "hanzo-gui-build clean:build",
    "test:web": "vitest --typecheck --run"
  },
  "dependencies": {
    "@hanzogui/compose-refs": "^2.0.0",
    "@hanzogui/constants": "^2.0.0",
    "@hanzogui/helpers": "^2.0.0",
    "@hanzogui/is-equal-shallow": "^2.0.0",
    "@hanzogui/native": "^2.0.0",
    "@hanzogui/normalize-css-color": "^2.0.0",
    "@hanzogui/timer": "^2.0.0",
    "@hanzogui/types": "^2.0.0",
    "@hanzogui/use-did-finish-ssr": "^2.0.0",
    "@hanzogui/use-event": "^2.0.0",
    "@hanzogui/use-force-update": "^2.0.0"
  },
  "devDependencies": {
    "@hanzogui/build": "^2.0.0",
    "@testing-library/react": "^16.1.0",
    "csstype": "^3.0.10",
    "react": ">=19",
    "react-dom": "*",
    "react-native": "0.83.2",
    "typescript": "~5.9.2",
    "vitest": "4.0.4"
  },
  "peerDependencies": {
    "react": ">=19",
    "react-dom": "*",
    "react-native": "*"
  }
}
